# --- Demo request form (choose ONE delivery method) ---
# Option A (recommended MVP): Resend transactional email
RESEND_API_KEY=
DEMO_NOTIFY_TO=demo@example.com
DEMO_NOTIFY_FROM=onboarding@resend.dev

# Option B: external endpoint (Formspree etc.) — set NEXT_PUBLIC_DEMO_FORM_ENDPOINT
# and the form will POST there instead of /api/demo-request
NEXT_PUBLIC_DEMO_FORM_ENDPOINT=

# --- Analytics / marketing (all optional; scripts render only when set) ---
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://[DOMAIN_NAME]
